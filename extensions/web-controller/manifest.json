{
  "manifest_version": 3,
  "name": "Lumi PageAgent Controller",
  "version": "1.2.1",
  "minimum_chrome_version": "120",
  "description": "Manually connects one Chrome tab so Lumi Web can control it with Gemini Live tools.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Connect this tab to Lumi",
    "default_icon": {
      "16": "icons/logo.png",
      "32": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["app-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
