{
  "manifest_version": 3,
  "name": "Lumi Live",
  "version": "0.0.1",
  "minimum_chrome_version": "120",
  "description": "A standalone Gemini Live voice agent with Lumi VTuber and PageAgent browser controls.",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/lumi-sidepanel.png",
    "32": "icons/lumi-sidepanel.png",
    "48": "icons/lumi-sidepanel.png",
    "128": "icons/lumi-sidepanel.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Lumi Live Side Panel",
    "default_icon": {
      "16": "icons/lumi-sidepanel.png",
      "32": "icons/lumi-sidepanel.png",
      "48": "icons/lumi-sidepanel.png",
      "128": "icons/lumi-sidepanel.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://generativelanguage.googleapis.com wss://generativelanguage.googleapis.com"
  }
}
