{
  "manifest_version": 3,
  "name": "Lumi Live",
  "version": "0.0.9",
  "minimum_chrome_version": "120",
  "description": "A Gemini Live voice agent with live video translation, reactive avatars, PageAgent browser controls, and MCP tools.",
  "permissions": ["activeTab", "identity", "offscreen", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/lumi-live.png",
    "32": "icons/lumi-live.png",
    "48": "icons/lumi-live.png",
    "128": "icons/lumi-live.png"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_title": "Toggle Lumi Live",
    "default_icon": {
      "16": "icons/lumi-live.png",
      "32": "icons/lumi-live.png",
      "48": "icons/lumi-live.png",
      "128": "icons/lumi-live.png"
    }
  },
  "side_panel": {
    "default_path": "side-panel/index.html"
  },
  "options_page": "settings/index.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https: http://localhost:* http://127.0.0.1:* wss://generativelanguage.googleapis.com"
  }
}
